[Unit]
Description=Quectel PPP Connection Service
After=network.target
Wants=network.target

[Service]
Type=simple

ExecStart=/home/pi/cellular/venv/bin/python /home/pi/cellular/ppp_conn.py
WorkingDirectory=/home/pi/cellular

Restart=always
RestartSec=10

User=root
Group=root

StandardOutput=journal
StandardError=journal

KillMode=control-group

TimeoutStartSec=60

[Install]
WantedBy=multi-user.target
